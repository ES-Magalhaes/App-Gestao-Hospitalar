<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <View
            android:id="@+id/view_patient_indicator"
            android:layout_width="4dp"
            android:layout_height="0dp"
            android:background="#00C853"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <ImageView
            android:id="@+id/img_patient_profile"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginStart="16dp"
            android:background="@drawable/ic_launcher_background"
            app:layout_constraintStart_toEndOf="@id/view_patient_indicator"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_patient_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Nome do Paciente"
            android:textStyle="bold"
            android:textSize="18sp"
            app:layout_constraintStart_toEndOf="@id/img_patient_profile"
            app:layout_constraintTop_toTopOf="@id/img_patient_profile" />

        <TextView
            android:id="@+id/tv_patient_details"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="34 anos • ID: #4429"
            android:textColor="#666666"
            app:layout_constraintStart_toEndOf="@id/img_patient_profile"
            app:layout_constraintTop_toBottomOf="@id/tv_patient_name" />

        <ImageView
            android:id="@+id/btn_edit_patient"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_edit"
            app:layout_constraintEnd_toStartOf="@id/btn_delete_patient"
            android:layout_marginEnd="16dp"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/btn_delete_patient"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_delete"
            app:tint="#D32F2F"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:layout_marginStart="16dp"
            android:background="#EEEEEE"
            app:layout_constraintTop_toBottomOf="@id/img_patient_profile" />

        <TextView
            android:id="@+id/lbl_ultima_visita"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:text="ÚLTIMA VISITA"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#666666"
            app:layout_constraintStart_toEndOf="@id/view_patient_indicator"
            app:layout_constraintTop_toBottomOf="@id/divider" />

        <TextView
            android:id="@+id/tv_patient_last_visit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="12 Mai, 2024"
            android:textColor="#1A1A1A"
            app:layout_constraintStart_toEndOf="@id/view_patient_indicator"
            app:layout_constraintTop_toBottomOf="@id/lbl_ultima_visita" />

        <TextView
            android:id="@+id/lbl_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="48dp"
            android:layout_marginTop="12dp"
            android:text="STATUS"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#666666"
            app:layout_constraintStart_toEndOf="@id/lbl_ultima_visita"
            app:layout_constraintTop_toBottomOf="@id/divider" />

        <TextView
            android:id="@+id/tv_patient_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="ESTÁVEL"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            app:layout_constraintStart_toStartOf="@id/lbl_status"
            app:layout_constraintTop_toBottomOf="@id/lbl_status" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ver prontuário >"
            android:textColor="#0D47A1"
            android:textStyle="bold"
            android:textSize="12sp"
            android:layout_marginTop="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_patient_status" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>