<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Cabeçalho -->

        <!-- Card Consultas Hoje -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Resumo do Dia"
            android:textColor="#1A1A1A"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="29dp"
            android:layout_marginBottom="16dp"
            android:text="Terça-feira, 24 de Outubro"
            android:textColor="#666666" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CONSULTAS HOJE"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="24"
                    android:textSize="48sp"
                    android:textStyle="bold"
                    android:textColor="#0D47A1"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Container para Novos Pacientes e Plantão -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <!-- Adicione dois MaterialCardViews aqui com weight="1" para dividirem o espaço -->
            <!-- ... -->
        </LinearLayout>

        <!-- Título Próximos Atendimentos -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Próximos atendimentos"
                android:textSize="18sp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="Ver todos"
                android:textColor="#0D47A1"/>
        </RelativeLayout>

        <!-- RecyclerView para a lista de pacientes -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_proximos_atendimentos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginBottom="24dp"/>

        <!-- Banner Informativo Geral -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#0D47A1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Informativo Geral"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="A ala norte passará por manutenção preventiva hoje às 22h."
                    android:textColor="#E0E0E0" />

                <Button
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:backgroundTint="#B3FFFFFF"
                    android:text="Saber mais"
                    android:textColor="#0D47A1" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Banner de Doutores -->

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/img_dashboard_hospital"
            android:layout_width="match_parent"
            android:layout_height="186dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="24dp"
            android:scaleType="centerCrop"
            android:src="@drawable/doutoresimage"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.App.RoundedCornersImage" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>